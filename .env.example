# Hallucination Gate — Environment Configuration

# Wallet that receives USDC payments (REQUIRED)
PAY_TO_ADDRESS=0xYourWalletAddress

# x402 Facilitator
# PayAI (no auth needed): https://facilitator.payai.network
# CDP (needs API keys): https://api.cdp.coinbase.com/platform/v2/x402
FACILITATOR_URL=https://facilitator.payai.network

# Network: Base Mainnet
NETWORK=eip155:8453

# LLM Backend — set at least one
# Gemini (free tier: 5 RPM, 1M tokens/day)
GEMINI_API_KEY=
# OpenRouter (pay-as-you-go)
OPENROUTER_API_KEY=
# OpenAI-compatible
OPENAI_API_KEY=

# Port
PORT=4021
